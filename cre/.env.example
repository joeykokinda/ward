# WARD CRE — environment seam (never commit a real .env)
# Simulation (cre workflow simulate, no --broadcast) needs NONE of these.
# Deploy / broadcast needs them.

# CRE account API key for non-interactive CLI use (alternative to `cre login`).
# Get it from app.chain.link/cre after creating an account.
CRE_API_KEY=

# Funded private key on the target chain (Arc Testnet), used only when
# broadcasting real txs or deploying. NOT needed for plain simulation.
CRE_ETH_PRIVATE_KEY=

# Arc Testnet RPC (also set in project.yaml; env override optional)
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
