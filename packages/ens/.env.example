# @ward/ens — environment seams. All optional; sane public-testnet defaults
# are baked in so the package runs with zero setup. Copy to .env to override.
# (Root .env.example is the single source of truth; these are
#  the ENS-specific keys to add there.)

# --- RPC endpoints (override the keyless public defaults in production) ---
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# --- WARD agent identity ---
WARD_ENS_ROOT=ward-agent.eth

# --- ENSIP-25 agent-registry verification (set once the agent is registered) ---
WARD_AGENT_REGISTRY=0x0000000000000000000000000000000000000000
WARD_AGENT_REGISTRY_CHAIN_ID=11155111
WARD_AGENT_ID=1

# --- discovery candidate set (handles the agent learned from registry events) ---
WARD_WORKER_HANDLES=mike,sara,deon,lena,raj

# --- live subname minting ONLY (owner of ward-agent.eth; keep secret) ---
# CONTROLLER_PRIVATE_KEY=0x...

# --- reputation pointer target (the deployed WorkerRegistry on Arc) ---
# ARC_CHAIN_ID=8008
# WORKER_REGISTRY=0x...

# --- override canonical ENS deployments if needed (defaults are Sepolia) ---
# ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
# ENS_PUBLIC_RESOLVER=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
# ENS_NAME_WRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8
# ENS_UNIVERSAL_RESOLVER=0xeEeEEEeE14D718C2B47D9923Deab1335E144EeEe
