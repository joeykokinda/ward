# WARD agent env seams. Copy to .env and fill in to flip DRY -> LIVE.
# Everything has a safe default; with NONE of these set, the agent runs fully
# offline (rules-based diagnosis, in-process fake sim, DRY chain).

# --- LLM diagnosis (diagnosis.py) ---
# Set this to use the Anthropic API for diagnosis. Unset => deterministic
# rules-based diagnosis (loop still runs).
ANTHROPIC_API_KEY=
# Optional model override. Defaults to claude-haiku-4-5 (cheapest; diagnosis is
# a small classification called only on new faults). Any LLM error => rules engine.
# WARD_LLM_MODEL=claude-haiku-4-5

# --- Device sim (sim_client.py) ---
# If reachable, the real sim is used; otherwise an in-process fake sim runs.
SIM_BASE_URL=http://localhost:8090

# --- Chain (chain.py): set ALL THREE to go LIVE; otherwise DRY mode ---
ARC_RPC_URL=
ARC_CHAIN_ID=
AGENT_PRIVATE_KEY=
USDC_ADDRESS=
# Where deployments/<chainId>.json + abis/ live (defaults to repo-root /deployments).
# WARD_DEPLOYMENTS_DIR=/abs/path/to/deployments

# --- Supabase (events.py) ---
# Set both to mirror agent_events into Supabase; otherwise in-memory only.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Server (server.py) ---
WARD_HOST=0.0.0.0
WARD_PORT=8080

# --- Spending policy (all in 6-decimal USDC units) ---
# Demo job amount 75 USDC = 75000000; owner-approval threshold 100 USDC.
WARD_JOB_AMOUNT=75000000
WARD_OWNER_THRESHOLD=100000000
WARD_PER_JOB_CAP=100000000
WARD_DAILY_CAP=500000000
WARD_JOB_DEADLINE=3600

# --- Loop timing ---
WARD_POLL_INTERVAL=5.0
WARD_ATTEST_POLL=2.0
WARD_ATTEST_TIMEOUT=60.0

# --- Worker roster (DRY / fallback when no on-chain registry) ---
# JSON list of {address,handle,ensName,skills,region,reputation}.
# WARD_WORKER_ROSTER=[{"address":"0x...","handle":"mike","ensName":"mike.ward-agent.eth","skills":"networking","region":"NYC","reputation":87}]

# --- Autonomous worker completion (demo) ---
# When true (default), after DISPATCH the agent drives the worker side itself
# (accept -> markWorkDone -> repair device -> attest -> settle) when it holds
# the dispatched worker's key (WARD_WORKER_KEYS; DRY mode always simulates it).
# Set false to hand off to a human "worker accepts via UI" path instead.
# WARD_AUTO_COMPLETE=true
