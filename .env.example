# WARD — environment template. Copy to .env (gitignored) and fill the blanks.
# PREFILLED values are live-verified Arc/CRE facts — leave them as-is.
# BLANK values are the credentials/accounts the build needs to go fully live.

# ── LLM (agent reasoning) ───────────────────────────────────────────────
# Without this the agent runs deterministic rules-based diagnosis (still demos).
ANTHROPIC_API_KEY=

# ── Arc Testnet (PREFILLED — live-verified) ─────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app
# Native USDC on Arc (gas is paid in USDC). Use this, not MockUSDC, for live deploy.
USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Chainlink CRE forwarder on Arc Testnet.
CRE_ARC_FORWARDER=0x76c9cf548b4179F8901cda1f8623568b58215E62

# ── Wallets (BLANK — fund via faucet) ───────────────────────────────────
# Contract deployer. A throwaway is in spike/arc/.env (0xDCe5..Aea4); fund it at
# https://faucet.circle.com (Arc Testnet -> USDC, captcha/browser-only), or use your own.
DEPLOYER_PRIVATE_KEY=
# The agent's own wallet (createJob/settle). Fund with Arc USDC too.
AGENT_PRIVATE_KEY=

# ── Chainlink CRE ───────────────────────────────────────────────────────
# Free key from app.chain.link -> Account Settings. Needed for headless `cre workflow simulate` (bounty evidence).
CRE_API_KEY=
# Funded key for live `cre` deploy / --broadcast (gas in USDC). Often same as AGENT/DEPLOYER.
CRE_ETH_PRIVATE_KEY=

# ── ENS (Sepolia) ───────────────────────────────────────────────────────
SEPOLIA_RPC_URL=
# Funded Sepolia controller that owns ward-agent.eth; mints worker subnames.
CONTROLLER_PRIVATE_KEY=
# Set once the agent is in a real onchain registry (for ENSIP-25 agent-registration record).
WARD_AGENT_REGISTRY=
WARD_AGENT_ID=
WARD_AGENT_CHAIN_ID=5042002

# ── Supabase (persistent demo state) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Frontend ────────────────────────────────────────────────────────────
# mock = zero-backend demo (default). supabase/live = read persisted state + agent feed.
NEXT_PUBLIC_DATA_ADAPTER=mock
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app
# Path to the canonical deployments dir (addresses + ABIs) once contracts are live-deployed.
NEXT_PUBLIC_DEPLOYMENTS=./deployments
# Agent SSE feed + device sim base URLs (local defaults; swap for Railway/cloudflared URLs).
NEXT_PUBLIC_AGENT_URL=http://localhost:8091
SIM_BASE_URL=http://localhost:8090

# ── Deploy tooling (only if you want me to deploy via CLI vs dashboard) ──
VERCEL_TOKEN=
RAILWAY_TOKEN=
